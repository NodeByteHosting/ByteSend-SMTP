# SMTP Server Configuration
# Copy this file to .env and update values for your deployment

# Node environment
NODE_ENV=production

# SMTP authentication username
SMTP_AUTH_USERNAME=bytesend

# Base URL for ByteSend (used in SMTP responses and forwarding)
BYTESEND_BASE_URL=https://bytesend.cloud

# TLS Mode for SMTP connections
# 'none'   - Plain SMTP, suitable when behind a reverse proxy (nginx, Traefik)
# 'manual' - Server handles TLS directly; requires SMTP_TLS_CERT_PATH and SMTP_TLS_KEY_PATH
SMTP_TLS_MODE=none

# TLS certificate and key paths (only used when SMTP_TLS_MODE=manual)
# SMTP_TLS_CERT_PATH=/certs/fullchain.pem
# SMTP_TLS_KEY_PATH=/certs/privkey.pem
